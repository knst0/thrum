{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepublish": "bun run build",
    "publish:core": "bun publish --access public --cwd packages/core/",
    "publish:solid": "bun publish --access public --cwd packages/solid-adapter/"
  },
  "devDependencies": {
    "oxfmt": "^0.42.0",
    "oxlint": "^1.56.0",
    "tsdown": "^0.21.4",
    "typescript": "^6.0.2"
  }
}
